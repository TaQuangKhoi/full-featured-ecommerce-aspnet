@model ECommerce.Shared.DTOs.BannerSettingDto?
@{
    ViewData["Title"] = "Site Settings";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6">
        <a asp-area="Admin" asp-controller="Admin" asp-action="Index" class="text-indigo-600 dark:text-indigo-400 hover:underline">← Back to Dashboard</a>
    </nav>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Site Settings</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Customize the homepage banner image and text.</p>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 px-4 py-3 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded-lg text-sm">
                @TempData["Success"]
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="mb-4 text-red-600 dark:text-red-400 text-sm"></div>

        <!-- Current Banner Preview -->
        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
        {
            <div class="mb-6">
                <p class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Current Banner Image</p>
                <div class="relative rounded-lg overflow-hidden h-48 bg-gray-100 dark:bg-gray-700">
                    <img src="@Model.ImageUrl" alt="Current banner" class="w-full h-full object-cover" />
                </div>
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1 truncate">@Model.ImageUrl</p>
            </div>
        }

        <form asp-area="Admin" asp-controller="AdminSettings" asp-action="Update" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Banner Image Upload -->
            <div class="mb-5">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Upload Banner Image</label>
                <input type="file" name="bannerImage" accept="image/*"
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Accepted formats: JPG, PNG, WebP, GIF. Maximum file size: 5 MB. Uploading a file overrides the URL below.</p>
            </div>

            <!-- Banner Image URL -->
            <div class="mb-5">
                <label for="bannerImageUrl" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Or enter an Image URL
                </label>
                <input type="url" id="bannerImageUrl" name="bannerImageUrl"
                       value="@Model?.ImageUrl"
                       placeholder="https://example.com/banner.jpg"
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Leave blank to clear the banner image (gradient background will be used).</p>
            </div>

            <!-- Banner Title -->
            <div class="mb-5">
                <label for="title" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Banner Title</label>
                <input type="text" id="title" name="title"
                       value="@Model?.Title"
                       placeholder="Welcome to ECommerce"
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Leave blank to use the default title.</p>
            </div>

            <!-- Banner Subtitle -->
            <div class="mb-6">
                <label for="subtitle" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Banner Subtitle</label>
                <input type="text" id="subtitle" name="subtitle"
                       value="@Model?.Subtitle"
                       placeholder="Discover amazing products at unbeatable prices."
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Leave blank to use the default subtitle.</p>
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-lg font-medium transition">
                Save Settings
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
