@model ECommerce.Shared.DTOs.DashboardDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Admin Dashboard</h1>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Orders</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalOrders</p>
                </div>
                <div class="bg-blue-100 dark:bg-blue-900 p-3 rounded-full">
                    <span class="text-2xl">📦</span>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Revenue</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">$@Model.TotalRevenue.ToString("F2")</p>
                </div>
                <div class="bg-green-100 dark:bg-green-900 p-3 rounded-full">
                    <span class="text-2xl">💰</span>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Products</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalProducts</p>
                </div>
                <div class="bg-purple-100 dark:bg-purple-900 p-3 rounded-full">
                    <span class="text-2xl">🏷️</span>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Customers</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalCustomers</p>
                </div>
                <div class="bg-orange-100 dark:bg-orange-900 p-3 rounded-full">
                    <span class="text-2xl">👥</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-1 sm:grid-cols-5 gap-4 mb-10">
        <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl p-4 text-center font-medium transition">
            Manage Products
        </a>
        <a asp-area="Admin" asp-controller="AdminOrders" asp-action="Index" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl p-4 text-center font-medium transition">
            Manage Orders
        </a>
        <a asp-area="Admin" asp-controller="AdminCart" asp-action="Index" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl p-4 text-center font-medium transition">
            Manage Carts
        </a>
        <a asp-area="Admin" asp-controller="AdminCategories" asp-action="Index" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl p-4 text-center font-medium transition">
            Manage Categories
        </a>
        <a asp-area="Admin" asp-controller="AdminSettings" asp-action="Index" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl p-4 text-center font-medium transition">
            Site Settings
        </a>
    </div>

    <!-- Recent Orders -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Recent Orders</h2>
        </div>
        @if (Model.RecentOrders?.Any() == true)
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Order ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Customer</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var order in Model.RecentOrders)
                        {
                            var statusColor = order.Status switch
                            {
                                "Delivered" => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300",
                                "Shipped" => "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300",
                                "Processing" => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300",
                                "Cancelled" => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300",
                                _ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
                            };

                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-750">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <a asp-area="Admin" asp-controller="AdminOrders" asp-action="Details" asp-route-id="@order.Id" class="text-indigo-600 dark:text-indigo-400 hover:underline">
                                        #@order.Id.ToString().Substring(0, 8).ToUpper()
                                    </a>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@order.CustomerEmail</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 rounded-full text-xs font-medium @statusColor">@order.Status</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white text-right">$@order.Total.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-6 text-center text-gray-500 dark:text-gray-400">No recent orders.</div>
        }
    </div>
</div>
