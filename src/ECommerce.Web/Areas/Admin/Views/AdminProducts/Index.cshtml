@model ECommerce.Shared.DTOs.PaginatedResult<ECommerce.Shared.DTOs.ProductDto>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Manage Products</h1>
        <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Create"
           class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition">
            + New Product
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded-lg text-sm">
            @TempData["Success"]
        </div>
    }

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
        @if (Model?.Items?.Any() == true)
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Product</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Category</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Price</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Stock</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var product in Model.Items)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-750">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900 dark:text-white">@product.Name</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@(product.CategoryName ?? "—")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">$@product.Price.ToString("F2")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@product.Stock</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (product.IsActive)
                                    {
                                        <span class="px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">Active</span>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">Inactive</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-3">
                                    <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Edit" asp-route-id="@product.Id"
                                       class="text-indigo-600 dark:text-indigo-400 hover:underline font-medium">Edit</a>
                                    <form asp-area="Admin" asp-controller="AdminProducts" asp-action="Delete" asp-route-id="@product.Id" method="post" class="inline"
                                          onsubmit="return confirm('Are you sure you want to delete this product?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="text-red-600 dark:text-red-400 hover:underline font-medium">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
                    <nav class="flex justify-center space-x-2">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" asp-route-page="@i"
                               class="px-4 py-2 rounded-lg text-sm font-medium transition @(i == Model.Page ? "bg-indigo-600 text-white" : "bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 border border-gray-300 dark:border-gray-600")">
                                @i
                            </a>
                        }
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="p-12 text-center text-gray-500 dark:text-gray-400">
                <p class="text-lg">No products yet.</p>
                <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Create" class="mt-4 inline-block text-indigo-600 dark:text-indigo-400 hover:underline">Create your first product</a>
            </div>
        }
    </div>
</div>
