@model ECommerce.Application.Products.Commands.UpdateProductCommand
@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as List<ECommerce.Shared.DTOs.CategoryDto> ?? new List<ECommerce.Shared.DTOs.CategoryDto>();
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6">
        <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" class="text-indigo-600 dark:text-indigo-400 hover:underline">← Back to Products</a>
    </nav>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Edit Product</h1>

        <div id="alert-success" class="hidden mb-4 px-4 py-3 rounded-lg bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-sm"></div>
        <div id="alert-error" class="hidden mb-4 px-4 py-3 rounded-lg bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 text-sm"></div>

        <form id="edit-product-form" novalidate
              data-index-url="@Url.Action("Index", "AdminProducts", new { area = "Admin" })">
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />

            <div class="mb-5">
                <label for="Name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Name</label>
                <input id="Name" name="Name" value="@Model.Name" placeholder="Product name"
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" required maxlength="200" />
                <span class="field-error text-red-500 text-sm mt-1" data-field="Name"></span>
            </div>

            <div class="mb-5">
                <label for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
                <textarea id="Description" name="Description" rows="4" placeholder="Product description"
                          class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" maxlength="2000">@Model.Description</textarea>
                <span class="field-error text-red-500 text-sm mt-1" data-field="Description"></span>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-5">
                <div>
                    <label for="Price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Price</label>
                    <input id="Price" name="Price" type="number" step="0.01" min="0.01" value="@Model.Price"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" required />
                    <span class="field-error text-red-500 text-sm mt-1" data-field="Price"></span>
                </div>
                <div>
                    <label for="Stock" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Stock</label>
                    <input id="Stock" name="Stock" type="number" min="0" value="@Model.Stock"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" required />
                    <span class="field-error text-red-500 text-sm mt-1" data-field="Stock"></span>
                </div>
            </div>

            <div class="mb-5">
                <label for="CategoryId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Category</label>
                <select id="CategoryId" name="CategoryId"
                        class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" required>
                    <option value="">Select a category</option>
                    @foreach (var cat in categories)
                    {
                        if (cat.Id == Model.CategoryId)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>
                <span class="field-error text-red-500 text-sm mt-1" data-field="CategoryId"></span>
            </div>

            <div class="mb-5">
                <label for="ImageUrl" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Image URL (optional)</label>
                <input id="ImageUrl" name="ImageUrl" value="@Model.ImageUrl" placeholder="https://..."
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" maxlength="500" />
                <span class="field-error text-red-500 text-sm mt-1" data-field="ImageUrl"></span>
            </div>

            <div class="mb-6">
                <label class="flex items-center space-x-3">
                    <input id="IsActive" name="IsActive" type="checkbox" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 text-indigo-600 focus:ring-indigo-500" @(Model.IsActive ? "checked" : "") />
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Active</span>
                </label>
            </div>

            <button type="submit" id="submit-btn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-lg font-medium transition">
                Update Product
            </button>
        </form>
    </div>
</div>

@section Scripts {
@Html.AntiForgeryToken()
<script src="~/js/admin-edit-product.js"></script>
}
