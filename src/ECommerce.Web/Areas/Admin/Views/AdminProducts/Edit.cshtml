@model ECommerce.Application.Products.Commands.UpdateProductCommand
@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as List<ECommerce.Shared.DTOs.CategoryDto> ?? new List<ECommerce.Shared.DTOs.CategoryDto>();
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6">
        <a asp-area="Admin" asp-controller="AdminProducts" asp-action="Index" class="text-indigo-600 dark:text-indigo-400 hover:underline">← Back to Products</a>
    </nav>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Edit Product</h1>

        <form asp-area="Admin" asp-controller="AdminProducts" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="mb-4 text-red-600 dark:text-red-400 text-sm"></div>

            <div class="mb-5">
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="Name" placeholder="Product name"
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Name" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <textarea asp-for="Description" rows="4" placeholder="Product description"
                          class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-5">
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                    <input asp-for="Price" type="number" step="0.01" min="0"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                    <span asp-validation-for="Price" class="text-red-500 text-sm mt-1"></span>
                </div>
                <div>
                    <label asp-for="Stock" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                    <input asp-for="Stock" type="number" min="0"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                    <span asp-validation-for="Stock" class="text-red-500 text-sm mt-1"></span>
                </div>
            </div>

            <div class="mb-5">
                <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Category</label>
                <select asp-for="CategoryId"
                        class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <option value="">Select a category</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div class="mb-5">
                <label asp-for="ImageUrl" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Image URL (optional)</label>
                <input asp-for="ImageUrl" placeholder="https://..."
                       class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="ImageUrl" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div class="mb-6">
                <label class="flex items-center space-x-3">
                    <input asp-for="IsActive" type="checkbox" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 text-indigo-600 focus:ring-indigo-500" />
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Active</span>
                </label>
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-lg font-medium transition">
                Update Product
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
