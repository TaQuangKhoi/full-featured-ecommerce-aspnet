@model ECommerce.Shared.DTOs.PaginatedResult<ECommerce.Shared.DTOs.OrderDto>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Manage Orders</h1>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
        @if (Model?.Items?.Any() == true)
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Order ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Customer</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var order in Model.Items)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-750">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <a asp-controller="Admin" asp-action="OrderDetails" asp-route-id="@order.Id" class="text-indigo-600 dark:text-indigo-400 hover:underline">
                                        #@order.Id.ToString().Substring(0, 8).ToUpper()
                                    </a>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@order.CustomerEmail</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <form asp-controller="Admin" asp-action="UpdateOrderStatus" asp-route-id="@order.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <select name="status" onchange="this.form.submit()"
                                                class="px-3 py-1 rounded-lg text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500">
                                            @foreach (var status in new[] { "Pending", "Processing", "Shipped", "Completed", "Cancelled" })
                                            {
                                                <option value="@status" selected="@(order.Status == status)">@status</option>
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white text-right">$@order.Total.ToString("F2")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                    <a asp-controller="Admin" asp-action="OrderDetails" asp-route-id="@order.Id"
                                       class="text-indigo-600 dark:text-indigo-400 hover:underline font-medium">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
                    <nav class="flex justify-center space-x-2">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a asp-controller="Admin" asp-action="Orders" asp-route-page="@i"
                               class="px-4 py-2 rounded-lg text-sm font-medium transition @(i == Model.Page ? "bg-indigo-600 text-white" : "bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 border border-gray-300 dark:border-gray-600")">
                                @i
                            </a>
                        }
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="p-12 text-center text-gray-500 dark:text-gray-400">
                <p class="text-lg">No orders found.</p>
            </div>
        }
    </div>
</div>
