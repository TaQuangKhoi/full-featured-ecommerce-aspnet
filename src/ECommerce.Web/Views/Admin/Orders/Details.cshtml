@model ECommerce.Shared.DTOs.OrderDto
@{
    ViewData["Title"] = "Order Details (Admin)";
    var statusColor = Model.Status switch
    {
        "Delivered" => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300",
        "Shipped" => "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300",
        "Processing" => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300",
        "Cancelled" => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300",
        _ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
    };
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6">
        <a asp-controller="Admin" asp-action="Orders" class="text-indigo-600 dark:text-indigo-400 hover:underline">← Back to Orders</a>
    </nav>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 md:p-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Order #@Model.Id.ToString().Substring(0, 8).ToUpper()</h1>
                <p class="text-gray-500 dark:text-gray-400 mt-1">Placed on @Model.OrderDate.ToString("MMMM dd, yyyy 'at' h:mm tt")</p>
                <p class="text-gray-500 dark:text-gray-400 mt-1">Customer: @Model.CustomerEmail</p>
            </div>
            <div class="mt-4 sm:mt-0">
                <form asp-controller="Admin" asp-action="UpdateOrderStatus" asp-route-id="@Model.Id" method="post" class="flex items-center space-x-2">
                    @Html.AntiForgeryToken()
                    <select name="status"
                            class="px-3 py-2 rounded-lg text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500">
                        @foreach (var status in new[] { "Pending", "Processing", "Shipped", "Delivered", "Cancelled" })
                        {
                            <option value="@status" selected="@(Model.Status == status)">@status</option>
                        }
                    </select>
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Update</button>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ShippingAddress))
        {
            <div class="mb-8">
                <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">Shipping Address</h3>
                <p class="text-gray-900 dark:text-white">@Model.ShippingAddress</p>
            </div>
        }

        <!-- Order Items -->
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Product</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Price</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Subtotal</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">@item.ProductName</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">$@item.UnitPrice.ToString("F2")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">@item.Quantity</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-medium text-gray-900 dark:text-white">$@((item.UnitPrice * item.Quantity).ToString("F2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="border-t border-gray-200 dark:border-gray-700 mt-4 pt-4 text-right">
            <span class="text-lg font-bold text-gray-900 dark:text-white">Total: $@Model.Total.ToString("F2")</span>
        </div>
    </div>
</div>
