@model ECommerce.Shared.DTOs.PaginatedResult<ECommerce.Shared.DTOs.ProductDto>
@{
    ViewData["Title"] = "Products";
    var categories = ViewBag.Categories as List<ECommerce.Shared.DTOs.CategoryDto> ?? new List<ECommerce.Shared.DTOs.CategoryDto>();
    var selectedCategory = ViewBag.SelectedCategory as string ?? "";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Products</h1>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar -->
        <aside class="w-full lg:w-64 flex-shrink-0">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 sticky top-24">
                <!-- Search -->
                <form asp-controller="Products" asp-action="Index" method="get" class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Search</label>
                    <input type="text" name="search" value="@searchTerm" placeholder="Search products..."
                           class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                    @if (!string.IsNullOrEmpty(selectedCategory))
                    {
                        <input type="hidden" name="category" value="@selectedCategory" />
                    }
                    <button type="submit" class="mt-2 w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded-lg text-sm font-medium transition">
                        Search
                    </button>
                </form>

                <!-- Categories -->
                <div>
                    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Categories</h3>
                    <ul class="space-y-2">
                        <li>
                            <a asp-controller="Products" asp-action="Index" asp-route-search="@searchTerm"
                               class="block px-3 py-2 rounded-lg text-sm @(string.IsNullOrEmpty(selectedCategory) ? "bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 font-medium" : "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700")">
                                All Products
                            </a>
                        </li>
                        @foreach (var cat in categories)
                        {
                            <li>
                                <a asp-controller="Products" asp-action="Index" asp-route-category="@cat.Slug" asp-route-search="@searchTerm"
                                   class="block px-3 py-2 rounded-lg text-sm @(selectedCategory == cat.Slug ? "bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 font-medium" : "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700")">
                                    @cat.Name
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <div class="flex-grow">
            @if (Model?.Items?.Any() == true)
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
                    @foreach (var product in Model.Items)
                    {
                        var initials = string.Join("", product.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
                        var colors = new[] { "from-pink-500 to-rose-500", "from-blue-500 to-cyan-500", "from-green-500 to-emerald-500", "from-purple-500 to-violet-500", "from-orange-500 to-amber-500" };
                        var color = colors[Math.Abs(product.Id.GetHashCode()) % colors.Length];

                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md hover:shadow-xl transition-shadow overflow-hidden group">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <div class="h-48 overflow-hidden">
                                        <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                    </div>
                                }
                                else
                                {
                                    <div class="h-48 bg-gradient-to-br @color flex items-center justify-center">
                                        <span class="text-4xl font-bold text-white opacity-80">@initials</span>
                                    </div>
                                }
                            </a>
                            <div class="p-5">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="block">
                                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 truncate">@product.Name</h3>
                                </a>
                                @if (!string.IsNullOrEmpty(product.CategoryName))
                                {
                                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">@product.CategoryName</p>
                                }
                                <div class="flex items-center justify-between mt-4">
                                    <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400">$@product.Price.ToString("F2")</span>
                                    <button @@click="addToCart('@product.Id', '@product.Name.Replace("'", "\\'")', @product.Price.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                            class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                                        Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="flex justify-center mt-10 space-x-2">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a asp-controller="Products" asp-action="Index"
                               asp-route-page="@i" asp-route-category="@selectedCategory" asp-route-search="@searchTerm"
                               class="px-4 py-2 rounded-lg text-sm font-medium transition @(i == Model.Page ? "bg-indigo-600 text-white" : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 border border-gray-300 dark:border-gray-600")">
                                @i
                            </a>
                        }
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-16">
                    <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                    <p class="mt-4 text-gray-500 dark:text-gray-400 text-lg">No products found.</p>
                    <a asp-controller="Products" asp-action="Index" class="mt-4 inline-block text-indigo-600 dark:text-indigo-400 hover:underline">Clear filters</a>
                </div>
            }
        </div>
    </div>
</div>
