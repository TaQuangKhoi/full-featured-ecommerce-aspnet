@model ECommerce.Shared.DTOs.ProductDto
@{
    ViewData["Title"] = Model.Name;
    var initials = string.Join("", Model.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
    var colors = new[] { "from-pink-500 to-rose-500", "from-blue-500 to-cyan-500", "from-green-500 to-emerald-500", "from-purple-500 to-violet-500", "from-orange-500 to-amber-500" };
    var color = colors[Math.Abs(Model.Id.GetHashCode()) % colors.Length];
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6">
        <a asp-controller="Products" asp-action="Index" class="text-indigo-600 dark:text-indigo-400 hover:underline">← Back to Products</a>
    </nav>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden" x-data="{ qty: 1 }">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
            <!-- Product Image Placeholder -->
            <div class="h-72 md:h-full min-h-[24rem] bg-gradient-to-br @color flex items-center justify-center">
                <span class="text-8xl font-bold text-white opacity-80">@initials</span>
            </div>

            <!-- Product Info -->
            <div class="p-8 flex flex-col justify-center">
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium mb-2">@Model.CategoryName</span>
                }
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">@Model.Name</h1>
                <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">@(Model.Description ?? "No description available.")</p>

                <div class="text-3xl font-bold text-indigo-600 dark:text-indigo-400 mb-4">$@Model.Price.ToString("F2")</div>

                <!-- Stock Status -->
                @if (Model.Stock > 0)
                {
                    <div class="flex items-center space-x-2 mb-6">
                        <span class="w-3 h-3 bg-green-500 rounded-full"></span>
                        <span class="text-green-600 dark:text-green-400 text-sm font-medium">In Stock (@Model.Stock available)</span>
                    </div>
                }
                else
                {
                    <div class="flex items-center space-x-2 mb-6">
                        <span class="w-3 h-3 bg-red-500 rounded-full"></span>
                        <span class="text-red-600 dark:text-red-400 text-sm font-medium">Out of Stock</span>
                    </div>
                }

                <!-- Quantity Selector & Add to Cart -->
                @if (Model.Stock > 0)
                {
                    <div class="flex items-center space-x-4">
                        <div class="flex items-center border border-gray-300 dark:border-gray-600 rounded-lg">
                            <button @@click="qty = Math.max(1, qty - 1)" class="px-3 py-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-l-lg transition">−</button>
                            <span x-text="qty" class="px-4 py-2 text-gray-900 dark:text-white font-medium min-w-[3rem] text-center"></span>
                            <button @@click="qty = Math.min(@Model.Stock, qty + 1)" class="px-3 py-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-r-lg transition">+</button>
                        </div>
                        <button @@click="addToCart('@Model.Id', '@Model.Name.Replace("'", "\\'")', @Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture), qty)"
                                class="flex-grow bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-medium transition text-center">
                            Add to Cart
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
