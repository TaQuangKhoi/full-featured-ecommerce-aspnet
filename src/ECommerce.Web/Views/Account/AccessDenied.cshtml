@{
    ViewData["Title"] = "Access Denied";
}

<div class="min-h-[60vh] flex items-center justify-center px-4 py-12">
    <div class="text-center">
        <div class="text-6xl mb-4">🚫</div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Access Denied</h1>
        <p class="text-gray-500 dark:text-gray-400 mb-8 max-w-md">You don't have permission to access this page. Please contact an administrator if you believe this is an error.</p>
        <a asp-controller="Home" asp-action="Index" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-medium transition">
            Go Home
        </a>
    </div>
</div>
