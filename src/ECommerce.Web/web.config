<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!-- stdoutLogEnabled="true" captures early startup output before Serilog is initialized.
           Log files are written to the 'logs\stdout' folder relative to the app root.
           Set stdoutLogEnabled="false" once the application is stable to avoid large log files. -->
      <aspNetCore processPath="dotnet"
                  arguments=".\ECommerce.Web.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
